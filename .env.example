# ===== LLM Configuration =====
# 选择 provider: qwen / deepseek / openai / ollama
LLM_PROVIDER=qwen

# 通义千问
QWEN_API_KEY=your_qwen_api_key_here
QWEN_MODEL=qwen-max

# DeepSeek（备选）
# LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# OpenAI（备选）
# LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Ollama 本地模型（备选，无需 API key）
# 使用前先启动 Ollama 并拉取模型：ollama pull qwen2.5:7b
# LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# 硅基流动 SiliconFlow（OpenAI 兼容 API）
# LLM_PROVIDER=siliconflow
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_MODEL=deepseek-v4-flash

# ===== Observability =====
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=metacraft-agent
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=http://localhost:3000

# ===== Database =====
DATABASE_URL=sqlite+aiosqlite:///./data/metacraft.db
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/metacraft

# ===== Vector Store =====
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=metacraft_cases

# ===== MES Integration =====
MES_API_BASE=http://localhost:8080/api
MES_API_KEY=your_mes_api_key

# ===== App Settings =====
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development
